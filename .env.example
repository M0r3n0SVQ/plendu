# Required — OpenAI API key with access to gpt-4o-mini (vision).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — Upstash Redis for distributed rate limiting.
# Without these, the API falls back to a per-instance in-memory limiter,
# which is fine for local dev but bypassable on Vercel serverless.
# Create a free Redis DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# Optional — Sentry error monitoring (free up to 5k events/month).
# Without this, Sentry no-ops and the app behaves identically.
# Create a project at https://sentry.io → copy the DSN from Settings → Client Keys.
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX

# Optional — only needed if you want sourcemap uploads at build time
# (better stack traces in Sentry). Generate at sentry.io → Settings → Auth Tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
